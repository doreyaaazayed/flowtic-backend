            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Admin1\",\n  \"email\": \"admin@test.com\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        }
      ]
